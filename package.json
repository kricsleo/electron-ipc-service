{
  "name": "electron-ipc-service",
  "type": "module",
  "version": "0.1.1",
  "packageManager": "pnpm@10.27.0",
  "description": "Type-safe Electron IPC functional call",
  "author": "Kricsleo <kricsleo@163.com>",
  "license": "MIT",
  "homepage": "https://github.com/kricsleo/electron-ipc-service#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kricsleo/electron-ipc-service.git"
  },
  "keywords": [
    "electron",
    "ipc",
    "functional",
    "typescript",
    "type-safe"
  ],
  "exports": {
    ".": {
      "import": "./dist/main.js",
      "require": "./dist/main.cjs"
    },
    "./preload": {
      "import": "./dist/preload.js",
      "require": "./dist/preload.cjs"
    },
    "./renderer": {
      "import": "./dist/renderer.js",
      "require": "./dist/renderer.cjs"
    }
  },
  "main": "./dist/main.cjs",
  "module": "./dist/main.js",
  "types": "./dist/main.d.cts",
  "typesVersions": {
    "*": {
      "*": [
        "./dist/*",
        "./*"
      ]
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=16.4.0"
  },
  "scripts": {
    "build": "tsdown",
    "release": "bumpp && npm publish",
    "prepublishOnly": "pnpm run build",
    "test": "vitest",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix"
  },
  "peerDependencies": {
    "electron": ">=7.0.0"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^6.7.3",
    "@total-typescript/tsconfig": "^1.0.4",
    "bumpp": "^10.3.2",
    "eslint": "^9.39.2",
    "tsdown": "^0.18.4",
    "typescript": "^5.9.3"
  }
}
